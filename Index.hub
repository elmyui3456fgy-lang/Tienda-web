<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"> <!-- ✅ ARREGLO CELULAR -->
    <title>Bokados Vedder</title>
    <style>
        /* ==========================================
           ESTILOS GENERALES - ADAPTADO A CELULAR
        ========================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: #ffffff;
            color: #000000;
            line-height: 1.5;
            font-size: 16px; /* ✅ TAMAÑO FIJO Y BUENO */
        }

        /* ===== ENCABEZADO ===== */
        header {
            background-color: #ffffff;
            padding: 1rem;
            text-align: center;
            border-bottom: 3px solid #ff7a00;
        }

        .logo img {
            max-width: 160px;
            height: auto;
        }

        header h1 {
            font-size: 1.4rem;
            margin: 0.5rem 0;
            color: #ff7a00;
        }

        header p {
            font-size: 0.9rem;
            color: #444;
        }

        /* ===== MENÚ - ARREGLADO PARA CELULAR ===== */
        nav {
            background-color: #000000;
            padding: 0.7rem 0.3rem;
            position: sticky;
            top: 0;
            z-index: 100;
            text-align: center;
        }

        nav a {
            color: #ffffff;
            margin: 0 0.6rem;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.9rem; /* ✅ MÁS PEQUEÑO PARA QUE QUEPA */
            cursor: pointer;
            display: inline-block;
            padding: 0.3rem 0;
        }

        nav a:hover {
            color: #ff7a00;
        }

        /* ⭐ SECCIONES COMO PÁGINAS ⭐ */
        section {
            display: none;
            padding: 1.2rem 1rem;
            max-width: 1200px;
            margin: 0 auto;
            min-height: calc(100vh - 150px);
        }

        section.activa {
            display: block;
        }

        h2 {
            color: #ff7a00;
            text-align: center;
            margin-bottom: 1.2rem;
            border-bottom: 2px solid #ff7a00;
            padding-bottom: 0.4rem;
            font-size: 1.3rem;
        }

        h3 {
            color: #000000;
            margin-bottom: 0.6rem;
            font-size: 1.1rem;
        }

        /* ===== CATÁLOGO - ✅ IMÁGENES PERFECTAS ===== */
        .catalogo-grid {
            display: grid;
            grid-template-columns: 1fr; /* ✅ 1 COLUMNA EN CELULAR */
            gap: 1.5rem;
        }

        @media (min-width: 600px) { /* ✅ 2 COLUMNAS EN TABLET/PC */
            .catalogo-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 900px) { /* ✅ 3 COLUMNAS EN PC GRANDE */
            .catalogo-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .producto {
            background-color: #ffffff;
            padding: 1rem;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            text-align: center;
            border: 1px solid #ddd;
            width: 100%;
        }

        /* ✅ LO MÁS IMPORTANTE: IMÁGENES SIEMPRE IGUALES Y CUADRADAS */
        .producto img {
            width: 100%;
            height: 180px; /* MISMA ALTURA PARA TODAS */
            object-fit: cover; /* ✅ RECORTA Y AJUSTA, NO DEFORMA */
            border-radius: 8px;
            margin-bottom: 0.8rem;
            background-color: #f3f3f3; /* ✅ COLOR SI NO CARGA LA FOTO */
            border: 1px solid #eee;
        }

        .opciones {
            width: 100%;
            padding: 0.5rem;
            margin-bottom: 0.8rem;
            border: 1px solid #000000;
            border-radius: 5px;
            font-size: 0.9rem;
        }

        .btn-carrito {
            background-color: #ff7a00;
            color: #ffffff;
            border: none;
            padding: 0.6rem 1rem;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: bold;
            transition: background 0.3s;
            width: 100%;
        }

        .btn-carrito:hover {
            background-color: #e67000;
        }

        .precio {
            font-weight: bold;
            font-size: 1.1rem;
            color: #000000;
            margin: 0.6rem 0;
        }

        /* ===== ACERCA DE NOSOTROS ===== */
        .acerca-contenido {
            background-color: #ffffff;
            padding: 1.2rem;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border-left: 4px solid #ff7a00;
            font-size: 0.95rem;
        }

        .acerca-contenido ul {
            margin-left: 1.2rem;
            margin-bottom: 0.8rem;
        }

        /* ===== CONTACTO ===== */
        .contacto-info {
            background-color: #ffffff;
            padding: 1.5rem 1rem;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            text-align: center;
        }

        .contacto-info a {
            color: #ff7a00;
            font-weight: bold;
            text-decoration: none;
        }

        .contacto-info a:hover {
            text-decoration: underline;
        }

        /* ===== PEDIDO Y CARRITO - ✅ ARREGLADO ===== */
        .pedido-contenedor {
            background-color: #ffffff;
            padding: 1rem;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .item-pedido {
            display: flex;
            flex-wrap: wrap; /* ✅ SE AJUSTA SI NO CABE */
            justify-content: space-between;
            align-items: center;
            padding: 0.7rem 0;
            border-bottom: 1px dashed #ccc;
            gap: 0.5rem;
        }

        .cantidad-controles {
            display: flex;
            gap: 0.4rem;
            align-items: center;
        }

        .btn-cantidad {
            background-color: #000000;
            color: #ffffff;
            border: none;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            cursor: pointer;
            font-weight: bold;
            font-size: 1rem;
        }

        .btn-eliminar {
            background-color: #ff3333;
            color: white;
            border: none;
            padding: 0.25rem 0.5rem;
            border-radius: 3px;
            cursor: pointer;
            font-size: 0.8rem;
        }

        .total-pedido {
            font-size: 1.2rem;
            font-weight: bold;
            text-align: right;
            margin-top: 1rem;
            color: #ff7a00;
        }

        .formulario-pedido {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid #eee;
        }

        input, textarea {
            width: 100%;
            padding: 0.7rem;
            margin: 0.5rem 0;
            border: 1px solid #000000;
            border-radius: 5px;
            font-size: 0.95rem;
        }

        .btn-enviar {
            background-color: #000000;
            color: #ffffff;
            border: none;
            padding: 0.8rem 1.5rem;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1rem;
            width: 100%;
            margin-top: 0.8rem;
        }

        .btn-enviar:hover {
            background-color: #ff7a00;
        }

        /* ===== PIE DE PÁGINA ===== */
        footer {
            background-color: #000000;
            color: #ffffff;
            text-align: center;
            padding: 1rem;
            margin-top: 1rem;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">
            <!-- ✅ PON TU ENLACE DE IMAGEN DEL LOGO AQUÍ -->
            <img src="https://instagram.ftkd1-1.fna.fbcdn.net/v/t51.82787-15/706780890_18088643189064344_6380737878789239585_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=111&ig_cache_key=MzkwNTk0NzY4MzQzMTgxMDc3OA%3D%3D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkZFRUQueHBpZHMuMTMzNC5zZHIucmVndWxhcl9waG90by5DMyJ9&_nc_ohc=t8OSj858aJYQ7kNvwHRNuBt&_nc_oc=AdqcqUQDL3yqcwauj_OeVTulaGkvsxPi__mqk5GglrTzPHEUSJur7RIcWYc1ROZ-Xms&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.ftkd1-1.fna&_nc_gid=9Y3_x-ZwWBF2kz5udElhtw&_nc_ss=7a22e&oh=00_Af4AkFW3VmxOGUT7CDeNU5Ibn4BgQ6YhXo0oVHtPuZfDtw&oe=6A1F7510" alt="BokadosVedder" class="logo-img">
        </div>
        <h1>Bokados Vedder</h1>
        <p>Productos artesanales con sabor e innovación</p>
    </header>

    <nav>
        <a onclick="mostrarSeccion('catalogo')">Catálogo</a>
        <a onclick="mostrarSeccion('nosotros')">Nosotros</a>
        <a onclick="mostrarSeccion('contacto')">Contacto</a>
        <a onclick="mostrarSeccion('pedido')">Pedido</a>
    </nav>

    <!-- ==========================================
           CATÁLOGO - ✅ AQUÍ PONES TUS ENLACES
    ========================================== -->
    <section id="catalogo" class="activa">
        <h2>Nuestros Productos</h2>
        <div class="catalogo-grid">

            <!-- ===== GALLETAS DE LIMÓN ===== -->
            <div class="producto">
                <!-- ✅ PEGA AQUÍ TU ENLACE DE INTERNET -->
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTosxN3wFI8S_UBYXMTqKUOJ5yKvxmNhuojjQ&s" alt="Galletas de limón">
                <h3>Galletas de Limón</h3>
                <p>Paquete de 12 unidades</p>
