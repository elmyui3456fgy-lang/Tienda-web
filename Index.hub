                <h3>Yogur de 2 Litros</h3>
                <p>Elige tu sabor:</p>
                <select id="sabor_yogur" class="opciones">
                    <option value="Kumis">Kumis</option>
                    <option value="Fresa">Fresa</option>
                    <option value="Mora">Mora</option>
                    <option value="Arequipe con pasas">Arequipe con pasas</option>
                    <option value="Melocotón">Melocotón</option>
