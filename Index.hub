                    <option value="Guanábana">Guanábana</option>
                </select>
                <div class="precio">$16.000</div>
                <button class="btn-carrito" onclick="agregarYogur()">
                    🛒 Agregar al carrito
                </button>
            </div>

            <!-- ===== ALFAJORES ESTRELLA ===== -->
            <div class="producto">
                <!-- ✅ PEGA AQUÍ TU ENLACE DE INTERNET -->
                <img src="data:image/jpeg;base64," alt="Alfajores">
                <h3>Alfajores en forma de Estrella</h3>
                <p>Paquete de 10 unidades</p>
                <div class="precio">$7.000</div>
                <button class="btn-carrito" onclick="agregarAlCarrito('Alfajores Estrella (Paquete 10)', 7000)">
                    🛒 Agregar al carrito
                </button>
            </div>

            <!-- ===== FRESAS CON CREMA ===== -->
            <div class="producto">
                <!-- ✅ PEGA AQUÍ TU ENLACE DE INTERNET -->
                <img src="data:image/jpeg;base64," alt="fresas">
                <h3>Fresas con Crema</h3>
                <p>Elige el tamaño:</p>
                <select id="tamano_fresas" class="opciones">
                    <option value="Pequeña (8oz)" data-precio="8000">Pequeña (8oz) - $8.000</option>
                    <option value="Mediana (12oz)" data-precio="12000">Mediana (12oz) - $12.000</option>
                    <option value="Grande (15oz)" data-precio="15000">Grande (15oz) - $15.000</option>
                </select>
                <div class="precio" id="precio_fresas_texto">$8.000</div>
                <button class="btn-carrito" onclick="agregarFresas()">
                    🛒 Agregar al carrito
                </button>
            </div>

        </div>
    </section>

    <section id="nosotros">
        <h2>Acerca de Nosotros</h2>
        <div class="acerca-contenido">
            <p><strong>Nombre de la empresa:</strong> “Bokados Vedder”</p><br>
            <p><strong>Tipo de empresa:</strong> Empresa enfocada a la elaboración y comercialización de productos artesanales comestibles especialmente productos de panadería y repostería.</p><br>
            <p><strong>Actividad económica:</strong> Producción y venta de alimentos artesanales como galletas, snacks y otros productos horneados con sabores innovadores y presentación atractiva para el consumidor.</p><br>
